{
  "expo": {
    "name": "Red Inspection",
    "slug": "red-inspection-checklist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ED1C29"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nuoyicloud.redinspectionchecklist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "This app needs microphone access to read smoke alarm data."
      }
    },
    "android": {
      "package": "com.nuoyicloud.redinspectionchecklist",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ED1C29"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "CAMERA",
        "FOREGROUND_SERVICE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidMicPermission",
      "./plugins/withRNAudioRecord",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "This app needs microphone access to read smoke alarm inspection data."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "This app needs camera access to take inspection photos.",
          "photosPermission": "This app needs photo library access to select inspection images."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "36aea8eb-8e6b-4e14-824e-8da8a2df9738"
      }
    },
    "owner": "nuoyicloud"
  }
}
